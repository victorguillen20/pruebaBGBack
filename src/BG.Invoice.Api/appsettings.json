{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=bg-invoice.db"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_USE_ENV_VAR_Jwt__Secret",
    "Issuer": "BG.Invoice.Api",
    "Audience": "BG.Invoice.Client",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
