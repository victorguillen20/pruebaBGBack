{
  "info": {
    "name": "BG Invoice API",
    "description": "API de facturación BG Invoice. Construida con .NET 10, Clean Architecture y SQLite.\n\nAutenticación: Bearer JWT. Login en POST /api/auth/login devuelve un token de 60 minutos.\n\nRoles:\n- Admin: acceso completo a usuarios, roles, categorías, productos, clientes, facturas y configuración.\n- Vendedor: dashboard, facturas propias, clientes (solo lectura/creación/edición), productos (solo lectura).\n- Sin autenticación: solo /health y Swagger.\n\nBase URL (dev): https://localhost:5001\nCredenciales por defecto: admin / Admin123!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "1. Auth",
      "description": "Endpoints de autenticación. El login extrae el token JWT y lo guarda en la variable de entorno {{token}} para usarlo en el resto de peticiones.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Inicia sesión con credenciales y devuelve un token JWT. Las respuestas incluyen datos del usuario y rol. Usa {{adminUsername}} / {{adminPassword}} por defecto."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set(\"token\", json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin123!\",\n  \"newPassword\": \"NewPass123!\",\n  \"confirmPassword\": \"NewPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            },
            "description": "Cambia la contraseña del usuario autenticado. Requiere contraseña actual, nueva y confirmación."
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"newvendor\",\n  \"email\": \"vendor3@bg.com\",\n  \"password\": \"Pass123!\",\n  \"confirmPassword\": \"Pass123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"roleId\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registra un nuevo usuario. Solo admin. Devuelve 201 Created."
          }
        }
      ]
    },
    {
      "name": "2. Me",
      "description": "Información del usuario autenticado.",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "me"]
            },
            "description": "Devuelve los datos del usuario autenticado y sus menús disponibles."
          }
        }
      ]
    },
    {
      "name": "3. Users (Admin)",
      "description": "Gestión de usuarios. Solo accesible por administradores.",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "roleId", "value": "", "disabled": true }
              ]
            },
            "description": "Lista paginada de usuarios. Filtro opcional por búsqueda (search) y rol (roleId). Solo admin."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Obtiene un usuario por su ID. Solo admin."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"newuser\",\n  \"email\": \"new@bg.com\",\n  \"password\": \"Pass123!\",\n  \"confirmPassword\": \"Pass123!\",\n  \"firstName\": \"First\",\n  \"lastName\": \"Last\",\n  \"roleId\": 2,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Crea un nuevo usuario. Asignar roleId=1 (Admin) o roleId=2 (Vendedor). Solo admin."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\",\n  \"roleId\": 1,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Actualiza los datos de un usuario existente. Solo admin."
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "DELETE",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Desactiva (soft delete) un usuario. No se puede desactivar el último administrador activo. Devuelve 409 en ese caso. Solo admin."
          }
        }
      ]
    },
